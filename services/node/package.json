{
  "dependencies": {
    "axios": "^1.13.2",
    "co-body": "^6.0.0",
    "ramda": "^0.25.0"
  },
  "devDependencies": {
    "@types/axios": "^0.14.4",
    "@types/co-body": "^0.0.3",
    "@types/jest": "^27.5.2",
    "@types/node": "^20.0.0",
    "@types/ramda": "types/npm-ramda#dist",
    "@vtex/api": "^7.0.0",
    "@vtex/tsconfig": "^0.5.6",
    "jest": "^27.5.1",
    "ts-jest": "^27.1.5",
    "typescript": "5.5.3"
  },
  "scripts": {
    "lint": "tsc --noEmit --pretty",
    "test": "jest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "rootDir": ".",
    "moduleNameMapper": {
      "^@vtex/api$": "<rootDir>/__tests__/__mocks__/vtex-api.ts"
    },
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "paths": {}
        }
      }
    }
  },
  "version": "0.2.0"
}
